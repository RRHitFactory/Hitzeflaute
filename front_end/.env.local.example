# Example environment configuration file
# Copy this to .env.local and modify for your setup

# Backend API configuration
# Use localhost for development on the same machine
# Use your local network IP (e.g., 192.168.1.100) for mobile/other device testing
# Use your server's domain or IP for production
NEXT_PUBLIC_BACKEND_HOST=localhost
NEXT_PUBLIC_API_BASE_URL=http://${NEXT_PUBLIC_BACKEND_HOST}:8000/api