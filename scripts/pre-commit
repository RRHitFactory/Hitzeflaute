#!/bin/bash

echo "Running pre-commit checks..."

# Change to the repository root directory
cd "$(git rev-parse --show-toplevel)" || exit 1

# Run the individual commands instead of using make pre-commit to avoid path issues
if make fix-imports && make format; then
    echo "Pre-commit checks passed!"
    
    # Add any modified files to the commit
    git add -u
    
    exit 0
else
    echo "Pre-commit checks failed!"
    echo "Please fix the issues and try committing again."
    exit 1
fi